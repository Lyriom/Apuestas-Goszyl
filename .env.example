# Base de datos PostgreSQL async usada por SQLAlchemy/Alembic
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/sistema_b

# Seguridad de sesión. Usa una clave larga y aleatoria en producción.
SECRET_KEY=cambiar-por-clave-larga-aleatoria
SESSION_COOKIE_NAME=sistema_b_session

# Keycloak / OpenID Connect
KEYCLOAK_URL=https://auth.gozsyl.cloud
KEYCLOAK_REALM=apuestas-ec
KEYCLOAK_CLIENT_ID=sistema-b
KEYCLOAK_CLIENT_SECRET=cambiar
KEYCLOAK_REDIRECT_URI=https://apuestas.gozsyl.cloud/auth/callback

# Vault Transit. Sistema B solo descifra contenido recibido desde Sistema A.
VAULT_URL=https://vault.gozsyl.cloud
VAULT_TOKEN=cambiar
VAULT_TRANSIT_KEY=featured-content-key

# API key compartida con Sistema A para POST /api/internal/featured-content
SISTEMA_A_API_KEY=cambiar-clave-compartida-con-sistema-a

# Aplicación pública
APP_URL=https://apuestas.gozsyl.cloud
APP_NAME=Apuestas EC
APP_DESCRIPTION=Comparador de cuotas LigaPro y Tri

# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO

# Whitelist de administradores. Cualquier email aquí entra a /admin sin
# necesidad de tener el rol "admin" en Keycloak. Separar por comas.
ADMIN_EMAILS=jriera@misiva.com.ec

# Scrapers Playwright reales
SCRAPERS_INITIAL_RUN_DELAY_SECONDS=30
SCRAPERS_INTERVAL_HOURS=2
SCRAPERS_TIMEOUT_SECONDS=60
